{
    "fields": {
        "name": {
            "type": "varchar",
            "readOnly": true,
            "maxLength": 255,
            "view": "views/fields/varchar"
        },
        "firstName": {
            "type": "varchar",
            "maxLength": 100,
            "trim": true
        },
        "lastName": {
            "type": "varchar",
            "maxLength": 255,
            "trim": true
        },
        "titulo": {
            "type": "varchar",
            "maxLength": 100,
            "trim": true
        },
        "tipoCliente": {
            "type": "enum",
            "options": ["", "fisica", "moral"],
            "default": ""
        },
        "genero": {
            "type": "enum",
            "options": ["", "m", "f"],
            "default": ""
        },
        "estadoCivil": {
            "type": "varchar",
            "maxLength": 100,
            "trim": true
        },
        "status": {
            "type": "enum",
            "options": ["enCartera", "inactivo", "enSeguimiento"],
            "default": "enCartera",
            "style": {
                "enCartera": "success",
                "inactivo": "default",
                "enSeguimiento": "warning"
            }
        },
        "emailAddress": {
            "type": "email"
        },
        "celular": {
            "type": "varchar",
            "maxLength": 100,
            "trim": true
        },
        "telCasa": {
            "type": "varchar",
            "maxLength": 100,
            "trim": true
        },
        "telOfna": {
            "type": "varchar",
            "maxLength": 100,
            "trim": true
        },
        "fechaAlta": {
            "type": "datetime"
        },
        "fechaNacimiento": {
            "type": "date"
        },
        "fechaModificacion": {
            "type": "datetime",
            "readOnly": true
        },
        "etiquetas": {
            "type": "text",
            "rows": 3
        },
        "oficina": {
            "type": "link",
            "view": "views/fields/link"
        },
        "asesor": {
            "type": "link",
            "view": "views/fields/link"
        },
        "createdAt": {
            "type": "datetime",
            "readOnly": true
        },
        "modifiedAt": {
            "type": "datetime",
            "readOnly": true
        },
        "createdBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "modifiedBy": {
            "type": "link",
            "readOnly": true,
            "view": "views/fields/user"
        },
        "assignedUser": {
            "type": "link",
            "view": "views/fields/user"
        },
        "teams": {
            "type": "linkMultiple",
            "view": "views/fields/teams"
        }
    },
    "links": {
        "oficina": {
            "type": "belongsTo",
            "entity": "Team"
        },
        "asesor": {
            "type": "belongsTo",
            "entity": "User"
        },
        "propiedadesComprador": {
            "type": "hasMany",
            "entity": "Propiedades",
            "foreign": "idClientesComprador"
        },
        "propiedadesVendedor": {
            "type": "hasMany",
            "entity": "Propiedades",
            "foreign": "idClientesVendedor"
        },
        "createdBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "modifiedBy": {
            "type": "belongsTo",
            "entity": "User"
        },
        "assignedUser": {
            "type": "belongsTo",
            "entity": "User"
        },
        "teams": {
            "type": "hasMany",
            "entity": "Team",
            "relationName": "EntityTeam",
            "layoutRelationshipsDisabled": true
        }
    },
    "collection": {
        "orderBy": "createdAt",
        "order": "desc",
        "textFilterFields": ["firstName", "lastName", "emailAddress", "celular"]
    }
}
